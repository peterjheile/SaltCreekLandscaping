FROM node:20-alpine

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_REVALIDATE_SECONDS

ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL}
ENV NEXT_PUBLIC_REVALIDATE_SECONDS=${NEXT_PUBLIC_REVALIDATE_SECONDS}

COPY package*.json /app/
RUN npm install

COPY . /app/

RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start"]